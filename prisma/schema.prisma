generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Product {
  id         Int       @id @default(autoincrement())
  name       String
  brand      String?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  categoryId Int
  tenantId   Int?
  category   Category  @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  tenant     Tenant?   @relation(fields: [tenantId], references: [id])
  variants   Variant[]

  @@index([tenantId])
  @@index([createdAt])
  @@index([name])
  @@index([categoryId])
}

model Category {
  id          Int         @id @default(autoincrement())
  tenantId    Int?
  name        String
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  catalogType CatalogType
  isActive    Boolean     @default(true)
  config      Json?
  tenant      Tenant?     @relation(fields: [tenantId], references: [id], onDelete: SetNull)
  products    Product[]

  @@unique([tenantId, name])
  @@index([name])
  @@index([catalogType])
  @@index([tenantId])
  @@index([isActive])
}

model Variant {
  id             Int             @id @default(autoincrement())
  productId      Int
  size           String
  color          String
  stock          Int             @default(0)
  createdAt      DateTime        @default(now())
  price          Decimal         @db.Decimal(10, 2)
  updatedAt      DateTime        @updatedAt
  sku            String?         @unique
  barcode        String?         @unique
  imagePath      String?
  material       String?
  powerWatts     String?
  customAttributes Json?
  tenantId       Int?
  orders         Order[]
  items          OrderItem[]
  stockMovements StockMovement[]
  product        Product         @relation(fields: [productId], references: [id], onDelete: Cascade)
  tenant         Tenant?         @relation(fields: [tenantId], references: [id])

  @@index([tenantId])
  @@index([productId])
  @@index([productId, size])
  @@index([productId, color])
  @@index([stock])
  @@index([createdAt])
}

model StockMovement {
  id        Int                 @id @default(autoincrement())
  variantId Int
  quantity  Int
  reason    StockMovementReason
  createdAt DateTime            @default(now())
  tenantId  Int?
  tenant    Tenant?             @relation(fields: [tenantId], references: [id])
  variant   Variant             @relation(fields: [variantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([variantId])
  @@index([createdAt])
  @@index([reason])
}

model Order {
  id           Int         @id @default(autoincrement())
  phone        String
  quantity     Int?
  variantId    Int?
  createdAt    DateTime    @default(now())
  customerName String
  instagram    String?
  notes        String?
  status       OrderStatus @default(NEW)
  updatedAt    DateTime    @updatedAt
  source       OrderSource @default(INSTAGRAM)
  tenantId     Int?
  tenant       Tenant?     @relation(fields: [tenantId], references: [id])
  variant      Variant?    @relation(fields: [variantId], references: [id])
  items        OrderItem[]

  @@index([tenantId])
  @@index([createdAt])
  @@index([status])
  @@index([source])
  @@index([variantId])
}

model OrderItem {
  id        Int      @id @default(autoincrement())
  orderId   Int
  variantId Int
  quantity  Int
  createdAt DateTime @default(now())
  order     Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  variant   Variant  @relation(fields: [variantId], references: [id])

  @@index([orderId])
  @@index([variantId])
}

model User {
  id           Int                @id @default(autoincrement())
  name         String
  email        String             @unique
  passwordHash String
  role         UserRole
  createdAt    DateTime           @default(now())
  updatedAt    DateTime           @updatedAt
  sessions     Session[]
  memberships  TenantMembership[]
}

model Session {
  id             Int      @id @default(autoincrement())
  token          String   @unique
  userId         Int
  expiresAt      DateTime
  createdAt      DateTime @default(now())
  activeTenantId Int?
  activeTenant   Tenant?  @relation(fields: [activeTenantId], references: [id])
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([activeTenantId])
  @@index([expiresAt])
}

model Tenant {
  id             Int                @id @default(autoincrement())
  name           String
  slug           String             @unique
  status         TenantStatus       @default(ACTIVE)
  catalogType    CatalogType
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt
  orders         Order[]
  products       Product[]
  sessions       Session[]
  stockMovements StockMovement[]
  subscription   Subscription?
  memberships    TenantMembership[]
  settings       TenantSettings?
  categories     Category[]
  variants       Variant[]

  @@index([status])
  @@index([catalogType])
}

model TenantMembership {
  id        Int      @id @default(autoincrement())
  tenantId  Int
  userId    Int
  role      UserRole
  createdAt DateTime @default(now())
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([tenantId, userId])
  @@index([tenantId])
  @@index([userId])
}

model Subscription {
  id                 Int                @id @default(autoincrement())
  tenantId           Int                @unique
  planCode           String?
  status             SubscriptionStatus @default(TRIALING)
  trialStart         DateTime?
  trialEnd           DateTime?
  currentPeriodStart DateTime?
  currentPeriodEnd   DateTime?
  cancelAtPeriodEnd  Boolean            @default(false)
  providerCustomerId String?
  providerSubId      String?
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt
  tenant             Tenant             @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([status])
}

model TenantSettings {
  id           Int      @id @default(autoincrement())
  tenantId     Int      @unique
  businessName String?
  logoUrl      String?
  primaryColor String?
  currency     String   @default("EUR")
  language     String   @default("sq")
  catalogConfig Json?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  tenant       Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
}

enum OrderStatus {
  NEW
  READY
  DONE
  CANCELED
}

enum OrderSource {
  INSTAGRAM
  STORE
  WHOLESALE
}

enum UserRole {
  SUPER_ADMIN
  SELLER
  WAREHOUSE
}

enum TenantStatus {
  ACTIVE
  SUSPENDED
  TRIALING
  EXPIRED
}

enum CatalogType {
  FOOTWEAR
  ELECTRONICS
  HOME_GOODS
  DECOR
}

enum SubscriptionStatus {
  TRIALING
  ACTIVE
  PAST_DUE
  CANCELED
  EXPIRED
}

enum StockMovementReason {
  INCOMING_STOCK
  CUSTOMER_RETURN
}
